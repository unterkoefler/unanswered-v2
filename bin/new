#!/usr/bin/env nu

def --env main [slug: string] {
  let date = date now | format date "%Y-%m-%d" 
  let filename = $"content/posts/($date)-($slug).md"
  let header = [
    "---",
    $"slug: \"($slug)\"",
    "title: \"TODO\"",
    "description: \"TODO\"",
    "---"
  ] | str join "\n"
  $header | save $filename
  $filename
}
  
